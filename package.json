{
  "name": "roket",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "lint": "eslint --ext ts src",
    "lint:fix": "eslint --ext .ts --fix src",
    "test": "ts-node node_modules/jasmine/bin/jasmine --config=jasmine.json",
    "test-coverage": "nyc -r text -e .ts -x \"tests/*.test.ts\" npm run test",
    "dev": "parcel serve index.html",
    "clean": "rimraf dist",
    "build": "parcel build index.html"
  },
  "devDependencies": {
    "@types/jasmine": "^4.0.3",
    "@types/node": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^5.2.0",
    "@typescript-eslint/parser": "^5.2.0",
    "eslint": "^8.1.0",
    "jasmine": "^4.1.0",
    "nyc": "^15.1.0",
    "parcel-bundler": "^1.12.5",
    "rimraf": "^3.0.2",
    "ts-node": "^10.7.0",
    "typescript": "^4.6.4"
  },
  "dependencies": {}
}
